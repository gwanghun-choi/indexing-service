# =============================================================================
# 애플리케이션 기본 설정
# =============================================================================
APP_ENV="dev"                                    # 환경: dev(개발), prd(운영)
APP_NAME="indexing-service"                      # 애플리케이션 이름
APP_PORT="1047"                                  # 애플리케이션 포트
DEBUG=True                                       # 디버그 모드 활성화
ALLOWED_URLS=["*"]                               # CORS 허용 URL

# =============================================================================
# 데이터베이스 설정
# =============================================================================

# PostgreSQL 메인 데이터베이스
POSTGRES_HOST="localhost"                        # PostgreSQL 호스트
POSTGRES_PORT=5432                               # PostgreSQL 포트
POSTGRES_USER="postgres"                         # PostgreSQL 사용자명
POSTGRES_PASSWORD="your_password"                # PostgreSQL 비밀번호
POSTGRES_DB="your_database"                      # PostgreSQL 데이터베이스명

# Milvus 벡터 데이터베이스
MILVUS_HOST="localhost"                          # Milvus 호스트
MILVUS_PORT=19530                                # Milvus 포트

# Redis 캐시 및 큐
REDIS_URL="redis://localhost:6379/0"            # Redis 연결 URL
REDIS_DEFAULT_TIMEOUT="18000"                    # Redis 기본 타임아웃(초)
REDIS_USER="your_redis_user"                     # Redis 사용자명
REDIS_PW="your_redis_password"                   # Redis 비밀번호
REDIS_QUEUE_ROUTER_URL="http://localhost:8000"   # Redis 큐 라우터 URL
REDIS_QUEUE_NAME="your-queue"                    # Redis 큐 이름
REDIS_QUEUE_USE="True"                           # Redis 큐 사용 여부

# =============================================================================
# 메시지 큐 설정 (RabbitMQ)
# =============================================================================
RABBITMQ_HOST="localhost"                        # RabbitMQ 호스트
RABBITMQ_PORT=5672                               # RabbitMQ 포트
RABBITMQ_USER="test"                            # RabbitMQ 사용자명
RABBITMQ_PASSWORD="test"                        # RabbitMQ 비밀번호
RABBITMQ_VHOST="/"                               # RabbitMQ 가상 호스트
CELERY_BROKER_URL="amqp://test:guest@localhost:5672//"  # Celery 브로커 URL

# =============================================================================
# 임베딩 모델 설정
# =============================================================================
EMBEDDING_MODEL="text-embedding-ada-002"        # 기본 임베딩 모델
NCP_API_KEY="your_ncp_api_key"                   # NCP API 키

# Naver Cloud 임베딩 API (키 1)
EMB_API_BASE="https://clovastudio.apigw.ntruss.com"
EMB_CLOVASTUDIO_API_KEY="your_clovastudio_api_key_1"
EMB_APIGW_API_KEY="your_apigw_api_key_1"
EMB_APP_ID="your_app_id_1"

# Naver Cloud 임베딩 API (키 2)
EMB_API_BASE_2="https://clovastudio.apigw.ntruss.com"
EMB_CLOVASTUDIO_API_KEY_2="your_clovastudio_api_key_2"
EMB_APIGW_API_KEY_2="your_apigw_api_key_2"
EMB_APP_ID_2="your_app_id_2"

# Naver Cloud 임베딩 API (키 3)
EMB_API_BASE_3="https://clovastudio.apigw.ntruss.com"
EMB_CLOVASTUDIO_API_KEY_3="your_clovastudio_api_key_3"
EMB_APIGW_API_KEY_3="your_apigw_api_key_3"
EMB_APP_ID_3="your_app_id_3"

# HuggingFace 임베딩 API
HUGGINGFACE_API_TOKEN="your_huggingface_token"

# Mistral 임베딩 API
MISTRAL_API_KEY="your_mistral_api_key"

# Cohere 임베딩 API
COHERE_API_KEY="your_cohere_api_key"

# =============================================================================
# 채팅 완료 모델 설정
# =============================================================================

# Naver Cloud HyperCLOVA X (키 1)
HCX_API_BASE="https://clovastudio.stream.ntruss.com"
HCX_CLOVASTUDIO_API_KEY="your_hcx_clovastudio_api_key_1"
HCX_APIGW_API_KEY="your_hcx_apigw_api_key_1"
HCX_MAX_OUTPUT_TOKENS="1500"

# Naver Cloud HyperCLOVA X (키 2)
HCX_API_BASE_2="https://clovastudio.stream.ntruss.com"
HCX_CLOVASTUDIO_API_KEY_2="your_hcx_clovastudio_api_key_2"
HCX_APIGW_API_KEY_2="your_hcx_apigw_api_key_2"
HCX_MAX_OUTPUT_TOKENS_2="1500"

# Naver Cloud HyperCLOVA X (키 3)
HCX_API_BASE_3="https://clovastudio.stream.ntruss.com"
HCX_CLOVASTUDIO_API_KEY_3="your_hcx_clovastudio_api_key_3"
HCX_APIGW_API_KEY_3="your_hcx_apigw_api_key_3"
HCX_MAX_OUTPUT_TOKENS_3="1500"

# OpenAI API
OPENAI_API_KEY="your_openai_api_key"
OPENAI_API_KEY1="your_openai_api_key_1"
OPENAI_API_KEY2="your_openai_api_key_2"

# Anthropic API
ANTHROPIC_API_KEY="your_anthropic_api_key"

# Perplexity API
PERPLEXITY_API_KEY="your_perplexity_api_key"

# Google Cloud API
GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"

# =============================================================================
# 인증 및 보안 설정
# =============================================================================
JWT_SECRET_KEY="your_jwt_secret_key"             # JWT 서명 검증용 비밀키
JWT_ALGORITHM="HS256"                            # JWT 서명 알고리즘 (HMAC-SHA256)
CRYPT_KEY="your_encryption_key"                  # 암호화/복호화용 비밀키

# =============================================================================
# 파일 저장소 설정 (NCP Object Storage)
# =============================================================================
NCP_ACCESS_KEY="your_ncp_access_key"             # NCP 액세스 키
NCP_SECRET_KEY="your_ncp_secret_key"             # NCP 시크릿 키
NCP_ENDPOINT_URL="https://kr.object.ncloudstorage.com"  # NCP 엔드포인트 URL
NCP_BUCKET_NAME="your_bucket_name"               # NCP S3 버킷명

# =============================================================================
# 파일 업로드 설정
# =============================================================================
UPLOAD_DIR="uploads"                             # 업로드 디렉토리
MAX_UPLOAD_SIZE=10485760                         # 최대 업로드 크기 (10MB)

# =============================================================================
# 문서 파싱 서비스 설정
# =============================================================================

# LlamaCloud 문서 파싱 API
LLAMACLOUD_API_KEY="your_llamacloud_api_key"

# Naver Cloud OCR API
OCR_APIGW_INVOKE_URL="your_ocr_api_url"
OCR_APIGW_INVOKE_URL2="your_ocr_api_url_2"
OCR_SECRET_KEY="your_ocr_secret_key"

# =============================================================================
# MCP Tools 설정
# =============================================================================
MCP_TOOLS_BASE_URL="http://mcp-tools:8007"

# =============================================================================
# Reranker 서비스 설정
# =============================================================================
# 원격 서버: http://reranker:8009
RERANKER_SERVICE_URL="http://reranker:8009"

# =============================================================================
# DOCX 파서 조직별 규칙 (선택 사항)
# =============================================================================
# 조직 고유의 문서 서식 규칙. 비워두면 해당 규칙이 비활성화됩니다.
# 구분선(---)을 삽입할 섹션 제목 정규식        예: "- 신규 .+? 기능 개발"
DOCX_SECTION_DIVIDER_PATTERN=""
# 표 셀에서 위키 링크로 인라인 처리할 호스트     예: "wiki.example.com"
DOCX_WIKI_LINK_HOST=""